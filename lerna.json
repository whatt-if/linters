{
  "version": "independent",
  "npmClient": "yarn",
  "useWorkspaces": true,
  "packages": ["packages/*"],
  "command": {
    "publish": {
      "conventionalCommits": true,
      "ignoreChanges": ["**/*.md"],
      "message": "chore(release): lerna publish"
    },
    "version": {
      "conventionalCommits": true,
      "createRelease": "github"
    }
  }
}
